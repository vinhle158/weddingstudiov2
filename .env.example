# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT configuration
JWT_SECRET="change-me-strong-random-secret"
JWT_EXPIRES_IN="24h"

# Server configuration
PORT="3000"
HOST="127.0.0.1"
CORS_ORIGIN="http://localhost:5173"

# Database credentials and URL
POSTGRES_PASSWORD="change-me-strong-password"
DATABASE_URL="postgresql://studio_user:change-me-strong-password@localhost:5432/studio_db?schema=public"

# Seed passwords for first-run initializations
SEED_ADMIN_PASSWORD="change-me-seed-admin-password"
SEED_SALES_PASSWORD="change-me-seed-sales-password"
