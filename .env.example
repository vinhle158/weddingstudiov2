# URL gốc của ứng dụng, dùng để tạo liên kết nội bộ và callback khi cần.
APP_URL="MY_APP_URL"

# Cấu hình JWT. Phải thay giá trị mẫu trước khi chạy.
JWT_SECRET="change-me-strong-random-secret"
JWT_EXPIRES_IN="24h"

# Cấu hình máy chủ local.
PORT="3000"
HOST="127.0.0.1"
CORS_ORIGIN="http://localhost:5173"

# Thông tin PostgreSQL local. Không dùng các giá trị mẫu này cho production.
POSTGRES_PASSWORD="change-me-strong-password"
DATABASE_URL="postgresql://studio_user:change-me-strong-password@localhost:5432/studio_db?schema=public"

# Mật khẩu seed chỉ dùng khi khởi tạo dữ liệu local lần đầu.
SEED_ADMIN_PASSWORD="change-me-seed-admin-password"
SEED_SALES_PASSWORD="change-me-seed-sales-password"
