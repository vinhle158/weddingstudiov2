  "rules": [
    { "concept_id": "CUSTOMER_LIST", "sql_fragment": "1=1", "default_params": {} },
    { "concept_id": "LEAD_LIST", "sql_fragment": "status = :status", "default_params": { "status": "consulting" } },
    { "concept_id": "ORDER_LIST", "sql_fragment": "status != :cancelled_status AND status != :delivered_status", "default_params": { "cancelled_status": "cancelled", "delivered_status": "delivered" } },
    { "concept_id": "TASK_LIST", "sql_fragment": "status != :done_status AND status != :cancelled_status", "default_params": { "done_status": "done", "cancelled_status": "cancelled" } },
    { "concept_id": "OVERDUE_TASKS", "sql_fragment": "status != :done_status AND status != :cancelled_status AND due_date < :today", "default_params": { "done_status": "done", "cancelled_status": "cancelled" } },
    { "concept_id": "MISSING_DEPOSITS", "sql_fragment": "status != :cancelled_status AND status != :delivered_status AND deposit_amount <= 0 AND total_amount > 0", "default_params": { "cancelled_status": "cancelled", "delivered_status": "delivered" } },
    { "concept_id": "MISSING_ASSIGNMENTS", "sql_fragment": "status != :cancelled_status AND status != :delivered_status AND NOT EXISTS (SELECT 1 FROM \"Task\" t WHERE t.order_id = \"Order\".id)", "default_params": { "cancelled_status": "cancelled", "delivered_status": "delivered" } },
    { "concept_id": "SCHEDULE_RANGE", "sql_fragment": "shoot_date BETWEEN :start_date AND :end_date", "default_params": { "start_date": "", "end_date": "" } },
